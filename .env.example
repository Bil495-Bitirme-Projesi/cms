# ============================================================
# CMS Environment Variables
# ============================================================
# Copy this file and rename to .env:
#   copy .env.example .env          (Windows)
#   cp .env.example .env            (Linux/Mac)
#
# Docker Compose and Spring Boot both read from .env.
# Defaults work out of the box for local development.
# ============================================================

# ── PostgreSQL ──
DB_NAME=cms_db
DB_URL=jdbc:postgresql://localhost:5432/cms_db
DB_USERNAME=cms_user
DB_PASSWORD=cms_password
DB_PORT=5432

# ── MinIO ──
MINIO_ENDPOINT=http://localhost:9000
# For docker-compose.deploy.yml: set MINIO_ENDPOINT to the nginx-minio HTTPS address.
# The deploy stack auto-mounts server.crt so MinioClient trusts the self-signed cert.
#   Windows Mobile Hotspot: MINIO_ENDPOINT=https://192.168.137.1:9443
#   Linux NetworkManager:   MINIO_ENDPOINT=https://10.42.0.1:9443
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=admin123
MINIO_BUCKET=anomaly-clips
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# HTTPS port nginx-minio listens on. Change if 9443 is already in use.
MINIO_HTTPS_PORT=9443

# ── JWT ──
# For production, generate a secure key: openssl rand -base64 32
JWT_SECRET=dGhpcyBpcyBhIGRldi1vbmx5IHNlY3JldCBrZXkgdGhhdCBtdXN0IGJlIGNoYW5nZWQ=

# ── Subsystem (AI Inference Node) ──
SUBSYSTEM_ID=ai-inference-node
SUBSYSTEM_SECRET=dev-only-subsystem-secret-change-in-prod

# ── Firebase ──
# Place firebase-service-account.json next to whichever compose file you run.
# LOCAL DEV: put it in src/main/resources/ (loaded from classpath, no env var needed).

# ── Deploy Stack (docker-compose.deploy.yml) ──
# GitHub organization or username that owns the ghcr.io package.
# Example: if your image is ghcr.io/bitiriciler32/cms, set GITHUB_ORG=bitiriciler32
GITHUB_ORG=bil495-bitirme-projesi
# Image tag to deploy. 'latest' always points to the last main-branch build.
CMS_VERSION=latest

